# Centaur Robotics — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
#
# All of these must also be set on Vercel (Project → Settings → Environment Variables).
# Ask Julian for the Supabase and Resend values.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: Supabase dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never exposed to the browser
# Get from: Supabase dashboard → Project → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (transactional email) ────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_your-key

# ─── Site ────────────────────────────────────────────────────────────────────
# Production: https://centaurrobotics.com
# Staging:    https://centaurrobotics1.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Staff auth ──────────────────────────────────────────────────────────────
# Comma-separated list of email addresses allowed to access /staff and /status
# e.g. julian@centaurrobotics.com,cieran@agency.com
STAFF_ALLOWED_EMAILS=

# ─── Staff API token ─────────────────────────────────────────────────────────
# Random string used to authenticate /api/status requests from the ctrl dashboard.
# Generate with: openssl rand -hex 32
# Must match STATUS_TOKEN on the ctrl Vercel project.
STATUS_TOKEN=

# ─── Sentry (error monitoring) ───────────────────────────────────────────────
# Create a free project at sentry.io → Projects → New → Next.js
# Get DSN from: Settings → Projects → your-project → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=centaur-web

